# Template for .env.test — copy to .env.test and fill in.
# Used by e2e tests (test/jest-e2e.json) via test/setup-env.ts.
# Values here OVERRIDE same-name vars from .env.

# === DATABASE — MUST point to a SEPARATE test database ===
# Same Atlas cluster, different DB name (e.g. project_nest_test).
# Example: mongodb+srv://USER:PASS@cluster.xxx.mongodb.net/project_nest_test?retryWrites=true&w=majority
DATABASE_URL=

# === JWT — any throwaway secret, не використовуй продовий ===
JWT_SECRET=test-secret-not-for-production
JWT_EXPIRES=1h

# === Infrastructure (same containers as dev — порти однакові, БД інша) ===
REDIS_URL=redis://localhost:6379
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=devMasterKey123
SMTP_HOST=localhost
SMTP_PORT=1025

# === External services — лиши порожніми щоб тести не зачіпали реальні ===
RESEND_API_KEY=
GOOGLE_CLIENT_ID=
SENTRY_DSN=
FRONTEND_URL=http://localhost:3000
